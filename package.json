{
  "name": "nos",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "NOS - world engine: shared types, JSON Schema, validator and O Coracao's procedural map generator.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "genworld": "tsx engine/scripts/genworld.ts",
    "mapascii": "tsx engine/scripts/mapascii.ts",
    "tick": "tsx scripts/tick.ts",
    "validate-world": "tsx engine/scripts/validate-world.ts",
    "validate-worlds": "tsx scripts/validate-worlds.ts",
    "lint:sprites": "node assets/tools/lint-sprites.js",
    "build:sprites": "node assets/tools/build.cjs",
    "respond-issues": "tsx scripts/respond-issues.ts",
    "art": "node tools/art-mcp/cli.cjs",
    "olhar": "node tools/bancadas/olhar.mjs",
    "ouvir": "node tools/bancadas/ouvir.mjs",
    "prancheta": "node tools/bancadas/prancheta.mjs",
    "res-bench": "node tools/bancadas/res-bench.mjs",
    "peca": "node tools/bancadas/olhar-peca.mjs",
    "porteiro": "node tools/bancadas/porteiro.mjs",
    "auditar": "node tools/bancadas/auditar.mjs",
    "bench": "node tools/bancadas/bench/benchmark.mjs"
  },
  "dependencies": {
    "ajv": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
