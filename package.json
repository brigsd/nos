{
  "name": "nos",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "NOS - world engine: shared types, JSON Schema, validator and O Coracao's procedural map generator.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "peca": "node tools/bancadas/olhar-peca.mjs",
    "oficina": "node tools/bancadas/oficina.mjs",
    "servir": "node tools/servir.mjs",
    "executar": "node tools/bancadas/executar.mjs",
    "sintetizar": "node tools/bancadas/sintetizar.mjs",
    "analisar": "node tools/bancadas/analisar.mjs",
    "somtela": "node tools/bancadas/somtela.mjs",
    "somexportar": "node tools/bancadas/somexportar.mjs",
    "somab": "node tools/bancadas/somab.mjs",
    "jogar": "node tools/bancadas/jogar.mjs",
    "porteiro": "node tools/bancadas/porteiro.mjs",
    "auditar": "node tools/bancadas/auditar.mjs",
    "bench": "node tools/bancadas/bench/benchmark.mjs",
    "mapa": "node tools/mapa/mapa.mjs",
    "mapa:check": "node tools/mapa/mapa.mjs --check",
    "docs:toc": "node tools/mapa/toc.mjs",
    "docs:toc:check": "node tools/mapa/toc.mjs --check"
  },
  "dependencies": {
    "ajv": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "playwright": "1.56.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
