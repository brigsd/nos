{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://brigsd.github.io/nos/engine/schema/world.schema.json",
  "title": "World",
  "description": "Official state of a NOS world (e.g. O Coração). Mirrors engine/types.ts field-for-field - the two must never drift apart.",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "width", "height", "tiles", "players", "events"],
  "properties": {
    "meta": { "$ref": "#/definitions/WorldMeta" },
    "width": { "type": "integer", "minimum": 1 },
    "height": { "type": "integer", "minimum": 1 },
    "tiles": {
      "type": "array",
      "description": "Row-major tile grid: index = y * width + x.",
      "items": { "$ref": "#/definitions/Tile" }
    },
    "players": {
      "type": "object",
      "description": "Living players indexed by GitHub login.",
      "propertyNames": { "$ref": "#/definitions/Login" },
      "additionalProperties": { "$ref": "#/definitions/Player" }
    },
    "events": {
      "type": "array",
      "items": { "$ref": "#/definitions/WorldEvent" }
    },
    "natives": {
      "type": "object",
      "description": "NPCs (os Nativos) inhabiting the world, indexed by id (v2).",
      "additionalProperties": { "$ref": "#/definitions/Native" }
    },
    "machines": {
      "type": "object",
      "description": "A Fábrica's 4 oficinas-sintetizador (v2.5, D-23/D-25a), indexed by id.",
      "propertyNames": { "$ref": "#/definitions/MachineId" },
      "additionalProperties": { "$ref": "#/definitions/Machine" }
    }
  },
  "definitions": {
    "Biome": {
      "type": "string",
      "enum": ["meadow", "forest", "water", "ruins", "core"]
    },
    "ResourceType": {
      "type": "string",
      "enum": ["wood", "stone", "pulse_fragment"]
    },
    "MachineId": {
      "type": "string",
      "enum": ["forja", "cozinha", "bancada", "estaleiro"]
    },
    "TileDeco": {
      "description": "Purely visual city decoration on a tile (R8 city migration, docs/CITY_PLAN.md) - mirrors engine/types.ts's TileDeco, pinned by an anti-drift test.",
      "type": "string",
      "enum": ["plaza", "pavement", "trail", "pylon", "arch", "arch_dormant", "mural_stone"]
    },
    "ItemId": {
      "description": "Every craftable item id (engine/fabrication.ts's ITEM_CATALOG) - hand-mirrored here, pinned by an anti-drift test.",
      "type": "string",
      "enum": [
        "luvas_de_forja",
        "armadura_de_pulso",
        "racao_de_viagem",
        "elixir_de_pulso",
        "peca_basica",
        "lanterna",
        "kit_de_ferramentas",
        "carrinho_de_maos",
        "bicicleta_do_nucleo"
      ]
    },
    "Login": {
      "description": "GitHub login shape: 1-39 chars, alphanumeric segments joined by single hyphens - no leading/trailing hyphen and no consecutive hyphens (GitHub itself forbids both).",
      "type": "string",
      "minLength": 1,
      "maxLength": 39,
      "pattern": "^[A-Za-z0-9]+(?:-[A-Za-z0-9]+)*$"
    },
    "Tile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["biome"],
      "properties": {
        "biome": { "$ref": "#/definitions/Biome" },
        "resource": { "$ref": "#/definitions/ResourceType" },
        "deco": { "$ref": "#/definitions/TileDeco" }
      },
      "allOf": [
        {
          "description": "City decoration never sits on water or on the Núcleo itself (CITY_PLAN: 'o rio continua protagonista', 'O Núcleo intocável').",
          "if": { "properties": { "deco": true }, "required": ["deco"] },
          "then": { "properties": { "biome": { "enum": ["meadow", "forest", "ruins"] } } }
        },
        {
          "description": "Wood only grows in forest tiles.",
          "if": { "properties": { "resource": { "const": "wood" } }, "required": ["resource"] },
          "then": { "properties": { "biome": { "const": "forest" } } }
        },
        {
          "description": "Stone is only quarried from ruins.",
          "if": { "properties": { "resource": { "const": "stone" } }, "required": ["resource"] },
          "then": { "properties": { "biome": { "const": "ruins" } } }
        },
        {
          "description": "Pulse fragments sit on the riverbank (meadow/forest ground), never on water itself.",
          "if": { "properties": { "resource": { "const": "pulse_fragment" } }, "required": ["resource"] },
          "then": { "properties": { "biome": { "enum": ["meadow", "forest"] } } }
        }
      ]
    },
    "Position": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "integer", "minimum": 0 },
        "y": { "type": "integer", "minimum": 0 }
      }
    },
    "Inventory": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "wood": { "type": "integer", "minimum": 0 },
        "stone": { "type": "integer", "minimum": 0 },
        "pulse_fragment": { "type": "integer", "minimum": 0 }
      }
    },
    "Player": {
      "type": "object",
      "additionalProperties": false,
      "required": ["login", "position", "inventory", "energy"],
      "properties": {
        "login": { "$ref": "#/definitions/Login" },
        "position": { "$ref": "#/definitions/Position" },
        "inventory": { "$ref": "#/definitions/Inventory" },
        "energy": { "type": "integer", "minimum": 0, "maximum": 100 },
        "pulso": {
          "description": "Pulso (₱) balance - v2 economy. Optional: absent means zero (players written before the economy existed).",
          "type": "integer",
          "minimum": 0
        },
        "items": {
          "description": "Crafted items (A Fábrica, v2.5) indexed by item id, quantities. Optional: absent means no crafted items (players written before A Fábrica existed).",
          "type": "object",
          "propertyNames": { "$ref": "#/definitions/ItemId" },
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "WorldMeta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "seed", "tickCount", "worldTime"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "seed": { "type": "string", "minLength": 1 },
        "tickCount": { "type": "integer", "minimum": 0 },
        "worldTime": { "type": "integer", "minimum": 0 }
      }
    },
    "WorldEvent": {
      "oneOf": [
        { "$ref": "#/definitions/PlayerJoinedEvent" },
        { "$ref": "#/definitions/PlayerMovedEvent" },
        { "$ref": "#/definitions/ResourceCollectedEvent" },
        { "$ref": "#/definitions/PlayerSaidEvent" },
        { "$ref": "#/definitions/CorePulseEvent" },
        { "$ref": "#/definitions/NativeSpokeEvent" },
        { "$ref": "#/definitions/TradeCompletedEvent" },
        { "$ref": "#/definitions/NativeRepliedEvent" },
        { "$ref": "#/definitions/ItemSynthesizedEvent" }
      ]
    },
    "PlayerJoinedEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "tick", "worldTime", "login"],
      "properties": {
        "type": { "const": "player_joined" },
        "tick": { "type": "integer", "minimum": 0 },
        "worldTime": { "type": "integer", "minimum": 0 },
        "login": { "$ref": "#/definitions/Login" }
      }
    },
    "PlayerMovedEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "tick", "worldTime", "login", "from", "to"],
      "properties": {
        "type": { "const": "player_moved" },
        "tick": { "type": "integer", "minimum": 0 },
        "worldTime": { "type": "integer", "minimum": 0 },
        "login": { "$ref": "#/definitions/Login" },
        "from": { "$ref": "#/definitions/Position" },
        "to": { "$ref": "#/definitions/Position" }
      }
    },
    "ResourceCollectedEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "tick", "worldTime", "login", "resource", "quantity", "position"],
      "properties": {
        "type": { "const": "resource_collected" },
        "tick": { "type": "integer", "minimum": 0 },
        "worldTime": { "type": "integer", "minimum": 0 },
        "login": { "$ref": "#/definitions/Login" },
        "resource": { "$ref": "#/definitions/ResourceType" },
        "quantity": { "type": "integer", "minimum": 1 },
        "position": { "$ref": "#/definitions/Position" }
      }
    },
    "PlayerSaidEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "tick", "worldTime", "login", "message"],
      "properties": {
        "type": { "const": "player_said" },
        "tick": { "type": "integer", "minimum": 0 },
        "worldTime": { "type": "integer", "minimum": 0 },
        "login": { "$ref": "#/definitions/Login" },
        "message": { "type": "string", "minLength": 1, "maxLength": 280 }
      }
    },
    "CorePulseEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "tick", "worldTime"],
      "properties": {
        "type": { "const": "core_pulse" },
        "tick": { "type": "integer", "minimum": 0 },
        "worldTime": { "type": "integer", "minimum": 0 }
      }
    },
    "NativeFaction": {
      "type": "string",
      "enum": ["wanderer", "merchant", "guardian"]
    },
    "Native": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "position", "behaviorTree", "behaviorState", "inventory", "hp", "faction"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "position": { "$ref": "#/definitions/Position" },
        "behaviorTree": { "type": "string", "minLength": 1 },
        "behaviorState": { "type": "string" },
        "inventory": { "$ref": "#/definitions/Inventory" },
        "hp": { "type": "integer", "minimum": 0 },
        "faction": { "$ref": "#/definitions/NativeFaction" }
      }
    },
    "Machine": {
      "description": "One of A Fábrica's 4 oficinas-sintetizador (v2.5, D-23/D-25a).",
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "position"],
      "properties": {
        "id": { "$ref": "#/definitions/MachineId" },
        "name": { "type": "string", "minLength": 1 },
        "position": { "$ref": "#/definitions/Position" }
      }
    },
    "NativeSpokeEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "tick", "worldTime", "nativeId", "message"],
      "properties": {
        "type": { "const": "native_spoke" },
        "tick": { "type": "integer", "minimum": 0 },
        "worldTime": { "type": "integer", "minimum": 0 },
        "nativeId": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1, "maxLength": 280 }
      }
    },
    "TradeCompletedEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "tick", "worldTime", "login", "nativeId", "given", "received", "pulsoDelta"],
      "properties": {
        "type": { "const": "trade_completed" },
        "tick": { "type": "integer", "minimum": 0 },
        "worldTime": { "type": "integer", "minimum": 0 },
        "login": { "$ref": "#/definitions/Login" },
        "nativeId": { "type": "string", "minLength": 1 },
        "given": { "$ref": "#/definitions/Inventory" },
        "received": { "$ref": "#/definitions/Inventory" },
        "pulsoDelta": {
          "description": "Net change in the player's ₱ balance: positive = earned, negative = paid, 0 = pure barter.",
          "type": "integer"
        }
      }
    },
    "NativeRepliedEvent": {
      "description": "A Native answering a specific player's /conversar (v2). Unlike native_spoke, it is addressed: login is who the Native replied to.",
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "tick", "worldTime", "nativeId", "login", "message"],
      "properties": {
        "type": { "const": "native_replied" },
        "tick": { "type": "integer", "minimum": 0 },
        "worldTime": { "type": "integer", "minimum": 0 },
        "nativeId": { "type": "string", "minLength": 1 },
        "login": { "$ref": "#/definitions/Login" },
        "message": { "type": "string", "minLength": 1, "maxLength": 280 }
      }
    },
    "ItemSynthesizedEvent": {
      "description": "A player synthesizing an item at an oficina (A Fábrica, v2.5, D-23/D-25a's /sintetizar).",
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "tick", "worldTime", "login", "machineId", "recipeId", "output"],
      "properties": {
        "type": { "const": "item_synthesized" },
        "tick": { "type": "integer", "minimum": 0 },
        "worldTime": { "type": "integer", "minimum": 0 },
        "login": { "$ref": "#/definitions/Login" },
        "machineId": { "$ref": "#/definitions/MachineId" },
        "recipeId": { "type": "string", "minLength": 1 },
        "output": {
          "type": "object",
          "additionalProperties": false,
          "required": ["itemId", "quantity"],
          "properties": {
            "itemId": { "$ref": "#/definitions/ItemId" },
            "quantity": { "type": "integer", "minimum": 1 }
          }
        }
      }
    }
  }
}
